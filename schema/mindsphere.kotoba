// Mindsphere clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace mindsphere {

    entity Device {
        id: string @unique
        serial: string
        model: string
        status: string
        firmware: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Telemetry {
        id: string @unique
        deviceId: string
        metric: string
        value: float
        recordedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Gateway {
        id: string @unique
        name: string
        location: string
        deviceCount: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Command {
        id: string @unique
        deviceId: string
        name: string
        payload: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Firmware {
        id: string @unique
        model: string
        version: string
        contentRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Alert {
        id: string @unique
        deviceId: string
        rule: string
        severity: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
